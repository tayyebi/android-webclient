# Copy this file to .env and fill in the values before running the server.
#
# Usage:
#   docker run --env-file .env -p 3000:3000 apk-builder
#
# Or when running locally:
#   export $(grep -v '^#' .env | xargs) && ./apk-builder

# ── Android SDK tool paths ──────────────────────────────────────────────────
AAPT_PATH=/path/to/android-sdk/build-tools/34.0.0/aapt
DX_PATH=/path/to/android-sdk/build-tools/34.0.0/dx
ZIPALIGN_PATH=/path/to/android-sdk/build-tools/34.0.0/zipalign
APKSIGNER_PATH=/path/to/android-sdk/build-tools/34.0.0/apksigner

# Path to android.jar for the target platform (min SDK 14 → android-28 works)
PLATFORM_JAR=/path/to/android-sdk/platforms/android-28/android.jar

# ── Signing keystore ────────────────────────────────────────────────────────
# Use the bundled debug.keystore for testing, or supply your own release keystore.
KEYSTORE_PATH=/path/to/release.keystore
KEYSTORE_PASS=your_keystore_password

# ── Server configuration ────────────────────────────────────────────────────
TEMPLATE_DIR=./template
JOBS_DIR=/tmp/apk_jobs
WORKER_SCRIPT=./build_worker.py
STATIC_DIR=./static
LISTEN_ADDR=0.0.0.0:3000
