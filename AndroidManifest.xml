<?xml version='1.0'?>
<manifest
	xmlns:a='http://schemas.android.com/apk/res/android'
	package='com.gordarg.app'
	a:versionCode='0'
	a:versionName='0'>

    <uses-permission a:name="android.permission.INTERNET" />
    <uses-permission a:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission a:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission a:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission a:name="android.permission.ACCESS_WIFI_STATE" />

    <uses-sdk a:targetSdkVersion="33"></uses-sdk>
    <uses-sdk a:minSdkVersion="14"></uses-sdk>

    <supports-screens
            a:resizeable="true"
            a:anyDensity="true"
        />

    <application a:label='@string/app_name'>
        <activity a:name='.MainActivity'>
             <intent-filter>
                <category a:name='android.intent.category.LAUNCHER'/>
                <action a:name='android.intent.action.MAIN'/>
             </intent-filter>
        </activity>
    </application>
</manifest>
